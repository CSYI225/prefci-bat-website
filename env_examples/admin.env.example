# Exemple de fichier .env pour l'ADMINISTRATION (Dashboard)
# Vite expose les variables commençant par VITE_ au frontend de l'admin

# URL de l'API Backend pour les requêtes du panneau d'administration
# En développement: http://localhost:3000
# En production, cela doit être l'URL où le backend est déployé (ex: https://api.votre-domaine.com)
VITE_API_URL=http://localhost:3000
