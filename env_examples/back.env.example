# Exemple de fichier .env pour le BACKEND (API, Base de données, Mails)
# Remplacez les valeurs de démonstration par celles de votre environnement de production

# URL de connexion à la base de données (MySQL)
# Format : mysql://utilisateur:mot_de_passe@hote:port/nom_de_la_base
DATABASE_URL="mysql://root:password@localhost:3306/prefci_bat_db"

# Clé secrète pour signer les tokens JWT (Authentification)
JWT_SECRET="votre_super_cle_secrete_ici"
# Durée de validité du token
JWT_EXPIRES_IN="1d"

# Configuration Serveur Mail (Nodemailer)
MAIL_HOST="smtp.votre-domaine.com"
MAIL_PORT=587
MAIL_USER="contact@votre-domaine.com"
MAIL_PASS="mot_de_passe_email"
# Email administrateur recevant les demandes de contact/devis
ADMIN_EMAIL="admin@prefci-bat.com"
