# Exemple de fichier .env pour le FRONTEND (Site Web)
# Vite expose les variables commençant par VITE_ au frontend

# URL de l'API Backend pour les requêtes frontend
# En développement: http://localhost:3000
# En production, cela doit être l'URL où le backend est déployé (ex: https://api.votre-domaine.com)
VITE_API_URL=http://localhost:3000
