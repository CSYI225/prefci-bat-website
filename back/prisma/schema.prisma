generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Page {
  idPage   Int       @id @default(autoincrement()) @map("id_page")
  nomPage  String    @db.VarChar(100) @map("nom_page")
  slug     String    @unique @db.VarChar(100)
  sections Section[]

  @@map("pages")
}

model Section {
  idSection  Int      @id @default(autoincrement()) @map("id_section")
  idPage     Int      @map("id_page")
  nomSection String   @db.VarChar(100) @map("nom_section")
  ordre      Int?     @default(0)
  
  page       Page     @relation(fields: [idPage], references: [idPage], onDelete: Cascade)
  champs     Champ[]
  blocs      Bloc[]

  @@map("sections")
}

model Champ {
  idChamp   Int      @id @default(autoincrement()) @map("id_champ")
  idSection Int      @map("id_section")
  nomChamp  String   @db.VarChar(100) @map("nom_champ")
  typeChamp String   @db.VarChar(50) @map("type_champ")
  
  section   Section  @relation(fields: [idSection], references: [idSection], onDelete: Cascade)
  valeurs   Valeur[]

  @@map("champs")
}

model Bloc {
  idBloc    Int      @id @default(autoincrement()) @map("id_bloc")
  idSection Int      @map("id_section")
  ordre     Int?     @default(0)
  
  section   Section  @relation(fields: [idSection], references: [idSection], onDelete: Cascade)
  valeurs   Valeur[]

  @@map("blocs")
}

model Valeur {
  idValeur  Int      @id @default(autoincrement()) @map("id_valeur")
  idChamp   Int      @map("id_champ")
  idBloc    Int?     @map("id_bloc")
  contenu   String?  @db.LongText
  
  champ     Champ    @relation(fields: [idChamp], references: [idChamp], onDelete: Cascade)
  bloc      Bloc?    @relation(fields: [idBloc], references: [idBloc], onDelete: Cascade)

  @@map("valeurs")
}

model Service {
  idService   Int      @id @default(autoincrement()) @map("id_service")
  titre       String   @db.VarChar(150)
  description String?  @db.Text
  image       String?  @db.LongText
  details     String?  @db.Text

  @@map("services")
}

model Category {
  idCategorie  Int           @id @default(autoincrement()) @map("id_categorie")
  nom          String        @db.VarChar(100)
  
  realisations Realisation[]

  @@map("categories")
}

model Realisation {
  idRealisation     Int       @id @default(autoincrement()) @map("id_realisation")
  titre             String    @db.VarChar(150)
  descriptionProjet String?   @db.Text @map("description_projet")
  descriptionClient String?   @db.Text @map("description_client")
  imageAvant        String?   @db.LongText @map("image_avant")
  imageApres        String?   @db.LongText @map("image_apres")
  idCategorie       Int?      @map("id_categorie")
  nomClient         String?   @db.VarChar(150) @map("nom_client")
  dateRealisation   DateTime? @db.Date @map("date_realisation")
  
  categorie         Category? @relation(fields: [idCategorie], references: [idCategorie], onDelete: SetNull)

  @@map("realisations")
}

model Admin {
  idAdmin        Int       @id @default(autoincrement()) @map("id_admin")
  nom            String    @db.VarChar(100)
  email          String    @unique @db.VarChar(150)
  motDePasseHash String    @db.Text @map("mot_de_passe_hash")
  role           String?   @default("admin") @db.VarChar(50)
  dateCreation   DateTime? @default(now()) @db.Timestamp(0) @map("date_creation")

  @@map("admins")
}

model DemandeDevis {
  idDemande      Int       @id @default(autoincrement()) @map("id_demande")
  nomClient      String    @db.VarChar(150) @map("nom_client")
  email          String    @db.VarChar(150)
  telephone      String?   @db.VarChar(50)
  serviceDemande String?   @db.VarChar(150) @map("service_demande")
  message        String?   @db.Text
  dateDemande    DateTime? @default(now()) @db.Timestamp(0) @map("date_demande")
  statut         String?   @default("en_attente") @db.VarChar(50)

  @@map("demandes_devis")
}
